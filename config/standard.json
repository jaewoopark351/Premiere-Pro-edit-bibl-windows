{
  "name": "standard",
  "silence": {
    "noise_db": -45.0,
    "min_silence": 0.5
  },
  "cuts": {
    "long_silence": 0.8,
    "start_wait": 1.0,
    "end_silence": 1.5,
    "pad_before": 0.12,
    "pad_after": 0.12,
    "repeat_gap": 0.8,
    "word_pad": 0.03,
    "false_start_ratio": 0.72,
    "hesitation_min": 0.55,
    "hesitation_pad": 0.06,
    "short_utterance_max_duration": 0.3
  },
  "policy": {
    "remove_fillers": false,
    "remove_hesitation": false,
    "acoustic_filler": false,
    "auto_delete_reasons": [
      "start_wait",
      "end_long_silence",
      "long_silence",
      "repeated_word",
      "repeated_phrase"
    ]
  },
  "stt": {
    "model": "openai/whisper-large-v3",
    "language": "ko",
    "allow_cpu_fallback": false
  }
}
